
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Property {
  id            String     @id @default(uuid())
  title         String
  description   String
  city          String
  image         String
  pricePerNight Float
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  amenities     Amenity[]
}

model Amenity {
  id         String     @id @default(uuid())
  name       String     @unique

  properties Property[]
}