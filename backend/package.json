{
  "name": "backend",
  "version": "1.0.0",
  "description": "HotenB Backend - Fastify GraphQL API",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "start:dev": "npm run db:push && npm run db:seed && npm run dev",
    "lint": "tsc --noEmit",
    "test": "echo \"TODO: Add tests\" && exit 0"
  },
  "keywords": [
    "fastify",
    "graphql",
    "prisma",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "^5.8.0",
    "fastify": "^5.8.5",
    "graphql": "^16.8.0",
    "mercurius": "^16.9.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prisma": "^5.8.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
